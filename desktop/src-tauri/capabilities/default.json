{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/refs/heads/dev/.schemas/capabilities.schema.json",
  "identifier": "default",
  "description": "Default capability set for Hone",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "shell:allow-open",
    "notification:default",
    "dialog:default",
    "fs:default",
    "process:default"
  ]
}
