{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/refs/heads/dev/.schemas/config.schema.json",
  "productName": "Hone",
  "version": "0.3.0-alpha",
  "identifier": "dev.hone.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "npm run build && npm run build:cli"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Hone",
        "width": 1280,
        "height": 820,
        "minWidth": 1024,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ws://localhost:* ws://127.0.0.1:* wss://* https://*; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data: https://*; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": ["icons/icon.ico"],
    "resources": [
      "resources/node/node.exe",
      "resources/dist/cli.js"
    ]
  },
  "plugins": {}
}
